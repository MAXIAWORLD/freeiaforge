# FreeIA Gateway — edit this file with your keys and run docker compose up --build
# This file is auto-created on first start if missing.

# ── Cloud providers (add any keys you have, leave blank to skip) ─────────────

# Priority 1 — 5,000 req/day — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Priority 2 — 14,400 req/day — https://console.groq.com
GROQ_API_KEY=

# Priority 3 — 1,000 req/day — https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# Priority 4 — 1,500 req/day — https://aistudio.google.com
GEMINI_API_KEY=

# Priority 5 — 1,000 req/day — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Priority 6 — 100 req/day — https://console.mistral.ai
MISTRAL_API_KEY=

# Priority 7 — 200 req/day — https://openrouter.ai
OPENROUTER_API_KEY=

# ── Ollama local (priority 9, zero-key fallback) ─────────────────────────────
# Requires Ollama running on the host machine (https://ollama.com)
# Inside Docker, host.docker.internal resolves to your host machine.
# Outside Docker, use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ── Provider order override (optional) ───────────────────────────────────────
# Comma-separated list to override default priority.
# Unlisted providers are appended in default order.
# Example: PROVIDER_ORDER=groq,gemini,ollama
PROVIDER_ORDER=

# ── Optional — paid fallback ─────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
