# FreeIA Gateway — edit this file with your keys and run docker compose up --build
# This file is auto-created on first start if missing.
#
# Tip: each provider also accepts a comma-separated XXX_API_KEYS form to pool
# multiple free-tier accounts. The pool rotates between keys and parks a key
# for 24h on 401/402/429 (key-level errors). Example:
#   GROQ_API_KEYS=key_one,key_two,key_three
# When XXX_API_KEYS is set it takes precedence over the single-key XXX_API_KEY.

# ── Cloud providers (add any keys you have, leave blank to skip) ─────────────

# Priority 1 — 5,000 req/day — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# CEREBRAS_API_KEYS=

# Priority 2 — 14,400 req/day — https://console.groq.com
GROQ_API_KEY=
# GROQ_API_KEYS=

# Priority 3 — 1,000 req/day — https://cloud.sambanova.ai
SAMBANOVA_API_KEY=
# SAMBANOVA_API_KEYS=

# Priority 4 — 1,500 req/day — https://aistudio.google.com
GEMINI_API_KEY=
# GEMINI_API_KEYS=

# Priority 5 — 1,000 req/day — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
# HUGGINGFACE_API_KEYS=

# Priority 6 — 40 RPM · 100+ models — https://build.nvidia.com
NVIDIA_NIM_API_KEY=
# NVIDIA_NIM_API_KEYS=

# Priority 7 — 10,000 req/day — https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Priority 8 — 200 req/day — https://openrouter.ai
OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=

# Priority 9 — 100 req/day — https://console.mistral.ai
MISTRAL_API_KEY=
# MISTRAL_API_KEYS=

# ── Ollama local (priority 10, zero-key fallback) ────────────────────────────
# Requires Ollama running on the host machine (https://ollama.com)
# Inside Docker, host.docker.internal resolves to your host machine.
# Outside Docker, use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ── Provider order override (optional) ───────────────────────────────────────
# Comma-separated list to override default priority.
# Unlisted providers are appended in default order.
# Example: PROVIDER_ORDER=groq,gemini,ollama
PROVIDER_ORDER=

# ── Optional — paid fallback ─────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ── Gateway config (optional, defaults shown) ────────────────────────────────
FREEAI_API_KEY=freeai
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.90
CB_FAILURE_THRESHOLD=3
CB_TIMEOUT_SECONDS=300
CB_HALF_OPEN_AFTER=300
